# Public RPC used by the browser for wallet balance reads and client-signed swaps.
# The free public endpoint is heavily rate-limited — use Helius/QuickNode/Triton for real use.
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# Public key ONLY of the wallet your worker service trades with. Never put a private
# key here — this value is exposed to the browser.
NEXT_PUBLIC_BOT_WALLET_ADDRESS=
