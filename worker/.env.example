# --- Wallet ---
# Base58-encoded private key of the trading wallet. NEVER commit this file with a real key.
# Use a dedicated "hot" wallet with only the SOL you're willing to risk — not your main wallet.
WALLET_PRIVATE_KEY=

# --- RPC ---
# Free public RPCs are heavily rate-limited and will cause missed snipes / failed rug checks.
# Use a paid RPC (Helius, QuickNode, Triton) for anything beyond testing.
RPC_URL=https://api.mainnet-beta.solana.com

# --- Mode ---
# true = simulate everything, no real transactions. Always start here.
DRY_RUN=true

# --- Discovery filters ---
MIN_LIQUIDITY_USD=3000
MAX_MARKET_CAP_USD=150000
MIN_TOKEN_AGE_MINUTES=2
MAX_TOKEN_AGE_MINUTES=180
MIN_5M_VOLUME_USD=1000

# --- Position sizing / risk ---
BUY_AMOUNT_SOL=0.05
MAX_CONCURRENT_POSITIONS=3
MAX_SLIPPAGE_BPS=1500
PRIORITY_FEE_LAMPORTS=200000

# --- Exit strategy ---
TAKE_PROFIT_LEVELS=100,300,900
TAKE_PROFIT_SELL_PCTS=40,30,30
STOP_LOSS_PCT=35
TRAILING_STOP_ACTIVATE_PCT=80
TRAILING_STOP_PCT=25
MAX_HOLD_MINUTES=180

# --- Optional: RugCheck API (no key needed for basic report endpoint as of writing) ---
RUGCHECK_BASE_URL=https://api.rugcheck.xyz/v1
